<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base app theme. Compose drives the actual UI colours; this only needs
         to be a no-action-bar theme with a sensible splash background. -->
    <style name="Theme.GuardDroid" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/white</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
